{
  "name": "project-runtime-contracts",
  "version": "0.4.0",
  "description": "Portable runtime protocol contracts for the Fates ecosystem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "docs/protocol-specification.md",
    "docs/version-negotiation.md",
    "docs/evolution-policy.md",
    "docs/contract-ownership.md",
    "docs/contract-ownership-matrix.md",
    "docs/conformance.md",
    "docs/glossary.md",
    "docs/distribution.md",
    "docs/downstream-migration.md",
    "docs/design-gates.md",
    "docs/adoption-baseline.md",
    "docs/ananke-adapter-report.md",
    "docs/dependency-advisory-review.md",
    "docs/decisions",
    "docs/ADR-XXXX-runtime-contracts-content-surface-preflight.md",
    "examples/adoption-baseline.example.json",
    "examples/compatibility-manifest.json",
    "fixtures/adoption-v1",
    "fixtures/compatibility-manifest"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run clean && npm run typecheck && npm run test && npm run build && npm run fixtures:validate && npm run package:verify && npm run pack:check",
    "fixtures:validate": "vitest run src/protocol/AdoptionFixtures.test.ts",
    "package:verify": "node scripts/verify-package-content.mjs",
    "pack:check": "npm pack --dry-run",
    "pack:smoke": "node scripts/packed-consumer-smoke.mjs",
    "ananke:consumer": "node scripts/ananke-packed-consumer.mjs",
    "baseline:create": "node scripts/create-adoption-baseline.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "runtime",
    "contracts",
    "protocol",
    "ananke",
    "mnemosyne"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "typescript": "^5.4.2",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "vitest": "^2.1.0",
    "@vitest/ui": "^2.1.0"
  }
}

