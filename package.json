{
  "name": "project-runtime-contracts",
  "version": "0.4.0",
  "description": "Shared runtime protocol contracts for Project Ananke and Project Mnemosyne",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run clean && npm run typecheck && npm run test && npm run build && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "runtime",
    "contracts",
    "protocol",
    "ananke",
    "mnemosyne"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "typescript": "^5.4.2",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "vitest": "^2.1.0",
    "@vitest/ui": "^2.1.0"
  }
}

